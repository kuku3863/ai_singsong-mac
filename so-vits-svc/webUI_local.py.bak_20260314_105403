            "project_name": project_name,
            "batch_size": batch_size,
            "num_workers": num_workers,
            "all_in_mem": all_in_mem
        }
        
        return f"训练已启动 (项目: {project_name})！\n配置已更新: Batch Size={batch_size}, Num Workers={num_workers}, All In Mem={all_in_mem}\n请查看弹出的黑色控制台窗口。", gr.update(value="⏳ 训练中 (Training in Progress)...", interactive=False, variant="secondary")
    except Exception as e:
        return f"启动失败: {e}", gr.update(value="🚀 开始/继续训练 (Start Training)", interactive=True, variant="primary")

